{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "croustibat/filament-jobs-monitor": "^4.2",
        "doctrine/dbal": "3.6.6",
        "dompdf/dompdf": "^2.0",
        "filament/actions": "^5.0",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/infolists": "^5.0",
        "filament/notifications": "^5.0",
        "filament/tables": "^5.0",
        "filament/widgets": "^5.0",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.47",
        "laravel/sanctum": "4.x-dev",
        "laravel/tinker": "^2.8",
        "leek/filament-workflows": "^1.5",
        "maatwebsite/excel": "^3.1",
        "phpseclib/phpseclib": "^3",
        "rappasoft/laravel-authentication-log": "^5.0",
        "spatie/laravel-backup": "^9.0",
        "stechstudio/filament-impersonate": "^5.0",
        "symfony/html-sanitizer": "^7.4",
        "ufee/amoapi": "0.9.3.5",
        "vgrish/yclients-sdk-php": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "filament/upgrade": "^5.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "Ufee\\Amo\\Base\\Models\\": "app/Overrides/Ufee/Amo/Base/Models/",
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "vendor/ufee/amoapi/src/Base/Models/ApiModel.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan horizon:publish --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "filament-workflow-engine",
            "type": "composer",
            "url": "https://filament-workflow-engine.composer.sh"
        }
    ]
}
