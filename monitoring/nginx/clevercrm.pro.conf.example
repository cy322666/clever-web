# /etc/nginx/sites-available/clevercrm.pro
#
# Требует DNS A-записи на один сервер:
# - app.clevercrm.pro
# - grafana.clevercrm.pro
# - prometheus.clevercrm.pro
# - alerts.clevercrm.pro
#
# ВАЖНО:
# 1) Сначала примените HTTP-конфиг и проверьте nginx -t.
# 2) Затем выпустите сертификаты:
#    certbot --nginx -d app.clevercrm.pro -d grafana.clevercrm.pro -d prometheus.clevercrm.pro -d alerts.clevercrm.pro
# 3) Certbot сам добавит SSL-блоки.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream clever_app {
    server 127.0.0.1:8080;
}

upstream clever_grafana {
    server 127.0.0.1:3000;
}

upstream clever_prometheus {
    server 127.0.0.1:9090;
}

upstream clever_alertmanager {
    server 127.0.0.1:9093;
}

server {
    listen 80;
    server_name app.clevercrm.pro;

    location / {
        proxy_pass http://clever_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 80;
    server_name grafana.clevercrm.pro;

    location / {
        proxy_pass http://clever_grafana;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 80;
    server_name prometheus.clevercrm.pro;

    auth_basic "Restricted";
    auth_basic_user_file /etc/nginx/.htpasswd-monitoring;

    location / {
        proxy_pass http://clever_prometheus;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

server {
    listen 80;
    server_name alerts.clevercrm.pro;

    auth_basic "Restricted";
    auth_basic_user_file /etc/nginx/.htpasswd-monitoring;

    location / {
        proxy_pass http://clever_alertmanager;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
